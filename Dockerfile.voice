FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY voice_server.py .
COPY green_agent/ green_agent/
COPY solar_client/ solar_client/
COPY src/ src/

EXPOSE 8001
CMD ["uvicorn", "voice_server:app", "--host", "0.0.0.0", "--port", "8001"]
